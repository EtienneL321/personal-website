# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# The address Resend sends FROM (must be on a domain verified in Resend)
RESEND_FROM_ADDRESS=

# The address where contact form submissions are delivered TO (your private email)
CONTACT_RECIPIENT_EMAIL=

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
